{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "jott",
  "version": "0.1.0",
  "identifier": "com.jott-app.jottapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4853",
    "beforeDevCommand": "JOTT_BUNDLED=true bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "externalBin": ["binaries/hono-server"],
    "resources": [],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
