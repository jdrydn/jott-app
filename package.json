{
  "name": "jottapp",
  "version": "0.0.0",
  "private": true,
  "description": "Jot it down — standalone, offline-first, timestamped journal.",
  "type": "module",
  "repository": "https://github.com/jdrydn/jott-app",
  "homepage": "https://jott-app.com",
  "bugs": "https://github.com/jdrydn/jott-app/issues",
  "author": "jdrydn <james@jdrydn.com> (https://jdrydn.com)",
  "license": "SEE LICENSE IN ./LICENSE",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:seed": "bun scripts/dev.ts --seed-db",
    "dev:backend": "bun --watch backend/index.ts",
    "dev:frontend": "bun --bun vite",
    "build": "bun scripts/build.ts",
    "build:backend": "bun build --compile --target=bun-darwin-arm64 ./backend/index.ts --outfile tauri/binaries/hono-server-aarch64-apple-darwin",
    "build:frontend": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "start": "bun backend/index.ts",
    "test": "bun test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "tauri:build": "bun tauri build",
    "tauri:dev": "bun tauri dev"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "marked": "^18.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ulid": "^3.0.2",
    "wouter": "^3.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-shell": "~2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.13"
  }
}
