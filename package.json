{
  "name": "jottapp",
  "version": "0.0.0",
  "private": true,
  "description": "Jot it down — standalone, offline-first, timestamped journal.",
  "type": "module",
  "engines": {
    "bun": ">=1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "dev:seed": "bun scripts/dev.ts --seed-db",
    "dev:backend": "bun --watch backend/index.ts",
    "dev:frontend": "bun --bun vite",
    "build": "bun scripts/build.ts",
    "build:frontend": "bun --bun vite build",
    "preview": "bun --bun vite preview",
    "start": "bun backend/index.ts",
    "test": "bun test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  }
}
